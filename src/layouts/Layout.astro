---
// src/layouts/Layout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface BreadcrumbItem {
  name: string;
  item: string;
}

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  breadcrumbs?: BreadcrumbItem[];
}

const {
  title = "Saudi Arabia Travel Guide 2026 | Destinations, Visa & FIFA 2034 | Saudi Travel Hub",
  description = "Your independent, expert travel guide to Saudi Arabia. Discover destinations, eVisa requirements, cultural tips, and complete FIFA 2034 World Cup planning resources.",
  canonicalUrl: canonicalUrlProp,
  ogImage = "https://images.unsplash.com/photo-1586724237569-f3d0c1dee8c6?q=80&w=1200",
  breadcrumbs: customBreadcrumbs
} = Astro.props;

// Derive canonical URL dynamically:
// - In production builds (PROD=true), always use the live domain regardless
//   of which host the build is served from (prevents staging.pages.dev URLs
//   from leaking into Google's index as duplicate-content signals).
// - In dev / preview builds, use the actual request origin so localhost and
//   preview deployments self-canonicalise correctly instead of pointing at prod.
// - An explicit prop passed by an individual page always wins (e.g. for pages
//   that need a canonical pointing at a different URL for pagination etc.).
const PROD_ORIGIN = "https://www.sauditravelhub.com";
const STAGING_ORIGIN = "https://sauditravelhub-astro.pages.dev";
const derivedCanonical = canonicalUrlProp ??
  (import.meta.env.PROD
    ? PROD_ORIGIN + Astro.url.pathname
    : STAGING_ORIGIN + Astro.url.pathname);

// JSON-LD Schema Objects
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Saudi Travel Hub",
  "url": "https://www.sauditravelhub.com/",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://www.sauditravelhub.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Saudi Travel Hub",
  "url": "https://www.sauditravelhub.com/",
  "logo": "https://www.sauditravelhub.com/saudi_favicon.png",
  "sameAs": [
    "https://twitter.com/sauditravelhub",
    "https://www.instagram.com/sauditravelhub",
    "https://www.linkedin.com/company/sauditravelhub",
    "https://www.tiktok.com/@sauditravelhub",
    "https://www.youtube.com/@sauditravelhub",
    "https://www.facebook.com/sauditravelhub"
  ]
};

const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html' || Astro.url.pathname === '';

// Breadcrumb Schema & Visible Items
let breadcrumbItems: { name: string; item: string; }[] = [];

if (customBreadcrumbs) {
  breadcrumbItems = customBreadcrumbs;
} else if (!isHomepage) {
  // Fallback: Generate dynamically from URL
  const paths = Astro.url.pathname.split('/').filter(Boolean);
  breadcrumbItems.push({
    name: "Home",
    item: PROD_ORIGIN + "/"
  });

  let accumulatedPath = "";
  paths.forEach((segment, index) => {
    accumulatedPath += `/${segment}`;
    
    const cleanSegment = segment.replace(/\.html$/, '');
    let name = cleanSegment
      .split('-')
      .map(word => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ');
      
    if (cleanSegment.toLowerCase() === 'faq') name = 'FAQ';
    if (cleanSegment.toLowerCase() === 'fifa-2034') name = 'FIFA 2034';
    if (cleanSegment.toLowerCase() === 'neom') name = 'NEOM';
    
    const isLast = index === paths.length - 1;
    const itemUrl = PROD_ORIGIN + accumulatedPath + (isLast || accumulatedPath.endsWith('.html') ? '' : '/');
    
    breadcrumbItems.push({
      name: name,
      item: itemUrl
    });
  });
}

// Convert breadcrumbItems to Schema format (ensuring sequential position starting at 1)
const breadcrumbSchemaElements = breadcrumbItems.map((item, index) => ({
  "@type": "ListItem",
  "position": index + 1,
  "name": item.name,
  "item": item.item
}));

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbSchemaElements
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="google-site-verification" content="NqPXYYsoZD2B1qBCatip9o0FSJc8zemm_j4Rek13gLE" />
  <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests" />
  
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="saudi arabia travel guide, saudi travel visa, saudi travel tips, saudi destinations, FIFA 2034 travel, hajj umrah guide, riyadh jeddah alula neom, saudi travel 2026" />
  <meta name="robots" content="index, follow" />
  {!import.meta.env.PROD && <meta name="robots" content="noindex, nofollow" />}
  
  <!-- Canonical and Alternate Locales -->
  <link rel="canonical" href={derivedCanonical} />
  <link rel="alternate" hreflang="en" href={derivedCanonical} />
  <link rel="alternate" hreflang="x-default" href={derivedCanonical} />
  
  <!-- Geographic Targeting -->
  <meta name="geo.region" content="SA" />
  <meta name="geo.placename" content="Saudi Arabia" />
  <meta name="geo.position" content="24.7136;46.6753" />
  <meta name="ICBM" content="24.7136, 46.6753" />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={derivedCanonical} />
  <meta property="og:site_name" content="Saudi Travel Hub" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Icons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/saudi-travel-logo.png" sizes="192x192" />
  
  <!-- Preconnects and Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://images.unsplash.com" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Outfit:wght@300;400;500;600;700&family=Noto+Kufi+Arabic:wght@300;400;600&display=swap" rel="stylesheet" />


  <!-- Structured Data JSON-LD -->
  {!isHomepage && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
  {!isHomepage && <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />}
  {!isHomepage && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
  <slot name="head" />
</head>
<body>
  <!-- Custom Cursor -->
  <div class="cursor" id="customCursor" aria-hidden="true">
    <div class="cursor-dot" id="cursorDot"></div>
    <div class="cursor-ring" id="cursorRing"></div>
  </div>

  <Header />

  {!isHomepage && breadcrumbItems.length > 0 && (
    <div class="breadcrumb-area">
      <div class="container breadcrumb-container">
        {breadcrumbItems.map((item, index) => (
          <>
            {index > 0 && <span class="breadcrumb-separator">/</span>}
            {index === breadcrumbItems.length - 1 ? (
              <span class="breadcrumb-current">{item.name}</span>
            ) : (
              <a href={item.item} class="breadcrumb-link">{item.name}</a>
            )}
          </>
        ))}
      </div>
    </div>
  )}

  <slot />

  <Footer />

  <!-- Cookie Consent Banner -->
  <div class="cookie-banner" id="cookieBanner" role="dialog" aria-label="Cookie consent" aria-describedby="cookie-desc">
    <p class="cookie-text" id="cookie-desc">We use cookies to enhance your browsing experience, analyze site traffic, and personalize content. By clicking "Accept", you consent to our use of cookies. Read our <a href="/privacy/">Privacy Policy</a>.</p>
    <div class="cookie-btns">
      <button class="cookie-reject" id="btnRejectCookies">Reject</button>
      <button class="cookie-accept" id="btnAcceptCookies">Accept All</button>
    </div>
  </div>

  <!-- Back to Top Button -->
  <a href="#" class="back-to-top" id="backToTop" aria-label="Back to top" title="Scroll to top">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
  </a>

  <!-- Layout Level Interactive Script -->
  <script>
    // 1. Custom Cursor Script
    const cursorDot = document.getElementById('cursorDot');
    const cursorRing = document.getElementById('cursorRing');
    if (cursorDot && cursorRing) {
      document.addEventListener('mousemove', function(e) {
        requestAnimationFrame(function() {
          cursorDot.style.left = e.clientX + 'px';
          cursorDot.style.top = e.clientY + 'px';
          cursorRing.style.left = e.clientX + 'px';
          cursorRing.style.top = e.clientY + 'px';
        });
      });
    }

    // 2. Nav Scroll Styling
    window.addEventListener('scroll', function() {
      const nav = document.getElementById('mainNav');
      if (nav) nav.classList.toggle('scrolled', window.scrollY > 50);
    });

    // 3. Scroll Reveal Observer
    const reveals = document.querySelectorAll('.reveal');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.12 });
      reveals.forEach(function(el) { io.observe(el); });
    } else {
      reveals.forEach(function(el) { el.classList.add('visible'); });
    }

    // 4. Back to Top Script
    const btt = document.getElementById('backToTop');
    if (btt) {
      window.addEventListener('scroll', function() {
        btt.classList.toggle('visible', window.scrollY > 500);
      });
      btt.addEventListener('click', function(e) {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    }

    // 5. Cookie Consent Banner Handling
    const cookieBanner = document.getElementById('cookieBanner');
    const btnAccept = document.getElementById('btnAcceptCookies');
    const btnReject = document.getElementById('btnRejectCookies');

    function handleCookies(accepted: boolean) {
      localStorage.setItem('cookieConsent', accepted ? 'accepted' : 'rejected');
      if (cookieBanner) cookieBanner.classList.remove('visible');
    }

    if (btnAccept) btnAccept.addEventListener('click', () => handleCookies(true));
    if (btnReject) btnReject.addEventListener('click', () => handleCookies(false));

    const consent = localStorage.getItem('cookieConsent');
    if (!consent) {
      setTimeout(function() {
        if (cookieBanner) cookieBanner.classList.add('visible');
      }, 1500);
    }
  </script>
</body>
</html>

<style>
  .breadcrumb-area {
    background: rgba(201, 168, 76, 0.03);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    margin-top: 72px; /* Push below fixed header */
  }
  .breadcrumb-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--white-dim);
  }
  .breadcrumb-link {
    color: var(--gold);
    text-decoration: none;
    font-weight: 700;
    transition: color var(--transition);
  }
  .breadcrumb-link:hover {
    color: var(--gold-light);
  }
  .breadcrumb-separator {
    color: var(--border);
    user-select: none;
  }
  .breadcrumb-current {
    color: var(--white-dim);
    font-weight: 500;
  }
</style>
