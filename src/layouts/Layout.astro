---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical = "https://www.sauditravelhub.com/" } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/png" href="/saudi_favicon.png" />
  
  <!-- JSON-LD Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Saudi Travel Hub",
    "url": "https://www.sauditravelhub.com/",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://www.sauditravelhub.com/search?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
