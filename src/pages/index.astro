<script>
  // 1. Stars Generator Script
  (function createStars() {
    const container = document.getElementById('starsContainer');
    if (!container) return;
    container.innerHTML = '';
    const fragment = document.createDocumentFragment();
    for (let i = 0; i < 80; i++) {
      const s = document.createElement('div');
      s.className = 'star';
      const size = Math.random() * 2 + 0.5;
      s.style.cssText = `width:${size}px;height:${size}px;top:${Math.random() * 100}%;left:${Math.random() * 100}%;--dur:${2 + Math.random() * 4}s;--delay:${Math.random() * 5}s;`;
      fragment.appendChild(s);
    }
    container.appendChild(fragment);
  })();

  // 2. Marquee Infinite Loop Cloner
  const mTrack = document.getElementById('marqueeTrack');
  if (mTrack) { mTrack.innerHTML += mTrack.innerHTML; }

  // 3. Tab Switching Logic
  const tabs = document.querySelectorAll('.booking-tab');
  const forms = document.querySelectorAll('.booking-form');

  function switchTab(id: string, btn: HTMLButtonElement) {
    forms.forEach(f => f.classList.remove('active'));
    tabs.forEach(t => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });

    const targetForm = document.getElementById(`form-${id}`);
    if (targetForm) targetForm.classList.add('active');
    if (btn) {
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
    }
  }

  tabs.forEach(tab => {
    tab.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const id = target.id.replace('tab-', '');
      switchTab(id, target);
    });
  });

  // External Tab Switch triggers (for Quick Book cards)
  const tabMapper: Record<string, number> = { hotels: 0, taxi: 1, tickets: 2, packages: 3 };
  
  function switchTabExternal(id: string) {
    const targetIdx = tabMapper[id];
    if (targetIdx !== undefined) {
      const targetBtn = tabs[targetIdx] as HTMLButtonElement;
      switchTab(id, targetBtn);
    }
  }

  // Quick Book card event listeners
  document.getElementById('qb-hotels')?.addEventListener('click', (e) => {
    e.preventDefault();
    switchTabExternal('hotels');
  });
  document.getElementById('qb-taxi')?.addEventListener('click', (e) => {
    e.preventDefault();
    switchTabExternal('taxi');
  });
  document.getElementById('qb-fifa')?.addEventListener('click', (e) => {
    e.preventDefault();
    switchTabExternal('tickets');
  });

  // 4. Booking Redirect Handler
  function handleBook(type: string) {
    let dest = '', checkin = '', checkout = '', guests = '';
    if (type === 'hotel') {
      const destEl = document.getElementById('hotel-dest') as HTMLInputElement;
      const checkinEl = document.getElementById('hotel-checkin') as HTMLInputElement;
      const checkoutEl = document.getElementById('hotel-checkout') as HTMLInputElement;
      const guestsEl = document.getElementById('hotel-guests') as HTMLInputElement;
      
      dest = destEl?.value || 'Saudi Arabia';
      checkin = checkinEl?.value || '';
      checkout = checkoutEl?.value || '';
      guests = guestsEl?.value || '2';
      
      window.open(`https://www.booking.com/searchresults.html?ss=${encodeURIComponent(dest)}&checkin=${checkin}&checkout=${checkout}&group_adults=${guests}`, '_blank');
    } else if (type === 'taxi') {
      window.open('https://www.uber.com/', '_blank');
    } else if (type === 'ticket') {
      window.open('https://www.fifa.com/fifaplus/en/tournaments/mens/worldcup/26702000-14a0-4be9-88c6-ff9e1e2e27c0', '_blank');
    } else if (type === 'package') {
      window.open('https://www.visitsaudi.com/en/plan-your-trip', '_blank');
    }
  }

  // Add click events to booking buttons
  document.getElementById('btn-search-hotels')?.addEventListener('click', () => handleBook('hotel'));
  document.getElementById('btn-book-taxi')?.addEventListener('click', () => handleBook('taxi'));
  document.getElementById('btn-check-tickets')?.addEventListener('click', () => handleBook('ticket'));
  document.getElementById('btn-view-packages')?.addEventListener('click', () => handleBook('package'));

  // 5. Newsletter Signup Handler
  const btnNewsletter = document.getElementById('newsletter-submit');
  const inputEmail = document.getElementById('newsletter-email') as HTMLInputElement;
  const msgNewsletter = document.getElementById('newsletter-msg');

  function handleNewsletter() {
    if (!inputEmail || !msgNewsletter) return;
    const email = inputEmail.value.trim();
    if (!email || !email.includes('@') || !email.includes('.')) {
      msgNewsletter.textContent = 'Please enter a valid email address.';
      msgNewsletter.style.color = '#c0392b';
      return;
    }
    msgNewsletter.textContent = `✓ Thank you! You'll receive FIFA 2034 updates at ${email}`;
    msgNewsletter.style.color = 'var(--gold)';
    inputEmail.value = '';
  }

  if (btnNewsletter) {
    btnNewsletter.addEventListener('click', handleNewsletter);
  }
</script>
