---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Saudi Arabia Travel Guide 2026 | Destinations, Visa & FIFA 2034 | Saudi Travel Hub" description="Your independent, expert travel guide to Saudi Arabia. Discover destinations, eVisa requirements, cultural tips, and complete FIFA 2034 World Cup planning resources.">
  <Header />

  <main id="main-content">
    <!-- HERO SECTION -->
    <section style="text-align: center; padding: 4rem 1rem; background: #f4f4f4;">
      <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">Discover the Kingdom of Saudi Arabia</h1>
      <p style="font-size: 1.125rem; max-width: 800px; margin: 0 auto 1rem;">
        Where ancient heritage meets visionary future. Explore breathtaking landscapes, rich culture, world-class hospitality — and the stage for FIFA World Cup 2034.
      </p>
      <p style="color: #666; font-size: 0.9rem; margin-bottom: 2rem;">
        <em>Last updated: April 2026 | Independent editorial guide · Written by on-the-ground experts</em>
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center;">
        <a href="/destinations/" style="background: #006C35; color: white; padding: 0.75rem 1.5rem; border-radius: 4px; text-decoration: none;">Explore Destinations</a>
        <a href="/booking" style="background: #fff; color: #006C35; border: 2px solid #006C35; padding: 0.75rem 1.5rem; border-radius: 4px; text-decoration: none;">Book Your Journey</a>
      </div>
    </section>

    <!-- DESTINATIONS GRID -->
    <section id="destinations" style="max-width: 1200px; margin: 3rem auto; padding: 0 1rem;">
      <h2 style="text-align: center; margin-bottom: 2rem;">Explore the Kingdom: Iconic Destinations</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
        <article style="border: 1px solid #eee; padding: 1.5rem; border-radius: 8px;">
          <h3>Riyadh</h3>
          <p>Capital City · FIFA 2034 Host. The beating heart of the Kingdom — Diriyah, Qiddiya, Kingdom Tower & beyond.</p>
          <a href="/destinations/riyadh/" style="color: #006C35; text-decoration: none; font-weight: bold;">Explore Riyadh →</a>
        </article>
        <article style="border: 1px solid #eee; padding: 1.5rem; border-radius: 8px;">
          <h3>Jeddah</h3>
          <p>Red Sea Gateway · UNESCO Heritage. Al-Balad's coral buildings, seafront corniche and world-class diving.</p>
          <a href="/destinations/jeddah/" style="color: #006C35; text-decoration: none; font-weight: bold;">Explore Jeddah →</a>
        </article>
        <article style="border: 1px solid #eee; padding: 1.5rem; border-radius: 8px;">
          <h3>AlUla</h3>
          <p>Ancient Wonder. Home to Hegra, Elephant Rock, and world-class desert hospitality.</p>
          <a href="/destinations/alula/" style="color: #006C35; text-decoration: none; font-weight: bold;">Explore AlUla →</a>
        </article>
        <article style="border: 1px solid #eee; padding: 1.5rem; border-radius: 8px;">
          <h3>NEOM</h3>
          <p>Future City. Discover The Line, Trojena, and the ultra-luxury Sindalah island.</p>
          <a href="/how-to-visit-neom-saudi-arabia-2026/" style="color: #006C35; text-decoration: none; font-weight: bold;">How to Visit NEOM →</a>
        </article>
      </div>
    </section>

    <!-- FIFA 2034 SECTION -->
    <section style="background: #001f3f; color: white; padding: 3rem 1rem; text-align: center;">
      <h2 style="margin-bottom: 1rem;">FIFA World Cup 2034: The World Comes to Saudi Arabia</h2>
      <p style="max-width: 700px; margin: 0 auto 2rem;">15 iconic stadiums, 8 host cities, and millions of fans. Plan your experience now.</p>
      <div style="display: flex; gap: 2rem; justify-content: center; margin-bottom: 2rem; font-weight: bold;">
        <span>15 Stadiums</span>
        <span>8 Host Cities</span>
        <span>104 Matches</span>
      </div>
      <a href="/fifa-world-cup-2034-saudi-arabia-hotels-where-to-stay/" style="background: #fff; color: #001f3f; padding: 0.75rem 1.5rem; border-radius: 4px; text-decoration: none; font-weight: bold;">Where to Stay for 2034</a>
    </section>

    <!-- LATEST GUIDES (CRUCIAL FOR SEO) -->
    <section style="max-width: 1200px; margin: 3rem auto; padding: 0 1rem;">
      <h2 style="text-align: center; margin-bottom: 2rem;">Latest Expert Travel Guides</h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        <article style="border: 1px solid #eee; padding: 1.5rem; border-radius: 8px;">
          <h3><a href="/best-time-to-visit-saudi-arabia-families-2026/" style="color: #333; text-decoration: none;">Best Time to Visit Saudi Arabia for Families (2026)</a></h3>
          <p>Discover the best months to visit with kids, weather guides, family-friendly events, and expert tips.</p>
        </article>
        <article style="border: 1px solid #eee; padding: 1.5rem; border-radius: 8px;">
          <h3><a href="/saudi-arabia-travel-budget-costs-2026/" style="color: #333; text-decoration: none;">Saudi Arabia Travel Budget 2026: Complete Cost Breakdown</a></h3>
          <p>How much does a trip to Saudi Arabia cost? Complete budget breakdown for flights, hotels, food, and transport.</p>
        </article>
        <article style="border: 1px solid #eee; padding: 1.5rem; border-radius: 8px;">
          <h3><a href="/how-to-book-alula-hegra-tickets-2026/" style="color: #333; text-decoration: none;">How to Book AlUla Hegra Tickets: Step-by-Step 2026</a></h3>
          <p>Learn exactly how to book Hegra (Madain Salih) tickets, prices, tour options, and essential visitor tips.</p>
        </article>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
