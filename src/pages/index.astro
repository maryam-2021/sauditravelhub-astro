---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Saudi Arabia Travel Guide 2026 | Destinations, Visa & FIFA 2034 | Saudi Travel Hub"
  description="Your independent, expert travel guide to Saudi Arabia. Discover destinations, eVisa requirements, cultural tips, and complete FIFA 2034 World Cup planning resources."
>
  <main id="main-content">
    
    <!-- HERO -->
    <section class="hero" aria-label="Welcome to Saudi Arabia">
      <div class="hero-geometric" aria-hidden="true">
        <div class="geo-ring"></div>
        <div class="geo-ring"></div>
        <div class="geo-ring"></div>
        <div class="geo-star"></div>
      </div>
      <div class="hero-pattern" aria-hidden="true"></div>
      <div class="stars" id="starsContainer" aria-hidden="true"></div>

      <div class="hero-content">
        <div class="hero-badge">
          <span class="hero-badge-dot" aria-hidden="true"></span>
          Independent Saudi Travel Guide · المملكة العربية السعودية
        </div>
        <h1 class="hero-heading">
          Discover the Best of<br />
          <em>Saudi Travel</em>
          <span class="line2">in the Kingdom</span>
        </h1>
        <div style="margin-top:1rem; font-size:0.8rem; color:var(--gold); text-transform:uppercase; letter-spacing:0.1em; font-weight:600;">Last updated: April 2026</div>
        <p class="hero-sub">Experience the best of <strong>Saudi travel</strong>. Where <strong>ancient heritage</strong> meets <strong>visionary future</strong>. Explore breathtaking landscapes, rich culture, world-class hospitality — and the stage for <strong>FIFA World Cup 2034</strong>.</p>
        <div class="hero-btns">
          <a href="#destinations" class="btn-primary">Explore Destinations</a>
          <a href="/booking" class="btn-outline">Book Your Journey</a>
        </div>
      </div>

      <div class="hero-stats" role="list" aria-label="Saudi Arabia facts">
        <div class="stat" role="listitem"><div class="stat-num">13+</div><div class="stat-label">UNESCO Sites</div></div>
        <div class="stat" role="listitem"><div class="stat-num">27M</div><div class="stat-label">Visitors in 2024</div></div>
        <div class="stat" role="listitem"><div class="stat-num">15</div><div class="stat-label">FIFA 2034 Stadiums</div></div>
        <div class="stat" role="listitem"><div class="stat-num">8</div><div class="stat-label">Host Cities</div></div>
      </div>

      <div class="scroll-cue" aria-hidden="true">
        <span class="scroll-text">Scroll</span>
        <div class="scroll-line"></div>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="marquee-section" aria-hidden="true">
      <div class="marquee-track" id="marqueeTrack">
        <span class="marquee-item">✦ <span>Riyadh</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>Jeddah</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>AlUla</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>NEOM</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>Abha</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>Red Sea</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>Diriyah</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>FIFA 2034</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>Al Khobar</span></span>
        <span class="marquee-item marquee-sep">·</span>
        <span class="marquee-item">✦ <span>Tabuk</span></span>
      </div>
    </div>

    <!-- TRUST BAR — E-E-A-T signal -->
    <div style="background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 1.2rem 3rem;" aria-label="Editorial credentials">
      <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: center; gap: 2rem 3rem; font-size: 0.8rem; color: var(--white-dim); letter-spacing: 0.04em;">
        <span style="display:flex;align-items:center;gap:0.5rem;"><span style="color:var(--gold);font-weight:700;">&#10003;</span> Independent editorial guide</span>
        <span style="display:flex;align-items:center;gap:0.5rem;"><span style="color:var(--gold);font-weight:700;">&#10003;</span> Written by on-the-ground experts</span>
        <span style="display:flex;align-items:center;gap:0.5rem;"><span style="color:var(--gold);font-weight:700;">&#10003;</span> Updated monthly &mdash; April 2026</span>
        <span style="display:flex;align-items:center;gap:0.5rem;"><span style="color:var(--gold);font-weight:700;">&#10003;</span> Visa info verified against official portals</span>
      </div>
    </div>

    <!-- BOOKING BAR -->
    <div class="booking-section" id="booking" role="region" aria-label="Book your trip">
      <div class="booking-tabs" role="tablist" aria-label="Booking options">
        <button class="booking-tab active" id="tab-hotels" role="tab" aria-selected="true" aria-controls="form-hotels">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Hotels
        </button>
        <button class="booking-tab" id="tab-taxi" role="tab" aria-selected="false" aria-controls="form-taxi">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Taxi & Transport
        </button>
        <button class="booking-tab" id="tab-tickets" role="tab" aria-selected="false" aria-controls="form-tickets">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          FIFA Tickets
        </button>
        <button class="booking-tab" id="tab-packages" role="tab" aria-selected="false" aria-controls="form-packages">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          Packages
        </button>
      </div>

      <!-- HOTELS FORM -->
      <form class="booking-form active" id="form-hotels" role="tabpanel" onsubmit="return false" aria-label="Search hotels">
        <div class="form-group">
          <label class="form-label" for="hotel-dest">Destination / City</label>
          <input id="hotel-dest" type="text" class="form-input" placeholder="Riyadh, Jeddah, AlUla…" />
        </div>
        <div class="form-group">
          <label class="form-label" for="hotel-checkin">Check In</label>
          <input id="hotel-checkin" type="date" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="hotel-checkout">Check Out</label>
          <input id="hotel-checkout" type="date" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="hotel-guests">Guests</label>
          <input id="hotel-guests" type="number" class="form-input" placeholder="2 Adults" min="1" value="2" />
        </div>
        <div class="form-group">
          <label class="form-label" for="hotel-budget">Budget</label>
          <select id="hotel-budget" class="form-input">
            <option>Any budget</option>
            <option>Budget (Under $100)</option>
            <option>Mid-range ($100–$300)</option>
            <option>Luxury ($300+)</option>
          </select>
        </div>
        <button class="booking-btn" id="btn-search-hotels">Search Hotels →</button>
      </form>

      <!-- TAXI FORM -->
      <form class="booking-form" id="form-taxi" role="tabpanel" onsubmit="return false" aria-label="Book taxi or transfer">
        <div class="form-group">
          <label class="form-label" for="taxi-pickup">Pickup Location</label>
          <input id="taxi-pickup" type="text" class="form-input" placeholder="Airport, Hotel, Stadium…" />
        </div>
        <div class="form-group">
          <label class="form-label" for="taxi-dest">Destination</label>
          <input id="taxi-dest" type="text" class="form-input" placeholder="Where to?" />
        </div>
        <div class="form-group">
          <label class="form-label" for="taxi-datetime">Date & Time</label>
          <input id="taxi-datetime" type="datetime-local" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="taxi-type">Vehicle Type</label>
          <select id="taxi-type" class="form-input">
            <option>Standard</option>
            <option>SUV / MPV</option>
            <option>Luxury</option>
            <option>Van (7+ seats)</option>
          </select>
        </div>
        <button class="booking-btn" id="btn-book-taxi">Book Ride →</button>
      </form>

      <!-- TICKETS FORM -->
      <form class="booking-form" id="form-tickets" role="tabpanel" onsubmit="return false" aria-label="Find FIFA 2034 tickets">
        <div class="form-group">
          <label class="form-label" for="ticket-stage">Stage / Round</label>
          <select id="ticket-stage" class="form-input">
            <option>Group Stage</option>
            <option>Round of 16</option>
            <option>Quarter Final</option>
            <option>Semi Final</option>
            <option>Final</option>
            <option>Opening Ceremony</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="ticket-city">Host City</label>
          <select id="ticket-city" class="form-input">
            <option>Riyadh</option>
            <option>Jeddah</option>
            <option>Al Khobar</option>
            <option>Abha</option>
            <option>NEOM</option>
            <option>Madinah</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="ticket-date">Match Date</label>
          <input id="ticket-date" type="date" class="form-input" />
        </div>
        <div class="form-group">
          <label class="form-label" for="ticket-qty">Tickets</label>
          <input id="ticket-qty" type="number" class="form-input" placeholder="2" min="1" max="10" value="2" />
        </div>
        <div class="form-group">
          <label class="form-label" for="ticket-cat">Category</label>
          <select id="ticket-cat" class="form-input">
            <option>Cat 1 — Standard</option>
            <option>Cat 2 — Premium</option>
            <option>Cat 3 — VIP</option>
            <option>Hospitality Box</option>
          </select>
        </div>
        <button class="booking-btn" id="btn-check-tickets">Check FIFA.com →</button>
        <p style="font-size:0.72rem; color:rgba(220,232,255,0.35); margin-top:0.8rem; grid-column: 1 / -1;">⚠ Official FIFA 2034 ticket sales have not yet opened. This button links to <a href="https://www.fifa.com/" target="_blank" rel="noopener" style="color:var(--gold);">FIFA.com</a> for the latest announcements. Bookmark this page &mdash; we will update as soon as sales begin.</p>
      </form>

      <!-- PACKAGES FORM -->
      <form class="booking-form" id="form-packages" role="tabpanel" onsubmit="return false" aria-label="Browse travel packages">
        <div class="form-group">
          <label class="form-label" for="pkg-type">Package Type</label>
          <select id="pkg-type" class="form-input">
            <option>FIFA Match Package</option>
            <option>Cultural Tour</option>
            <option>Desert Adventure</option>
            <option>Red Sea Luxury</option>
            <option>Full Kingdom Tour</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="pkg-city">Start City</label>
          <input id="pkg-city" type="text" class="form-input" placeholder="Riyadh, Jeddah…" />
        </div>
        <div class="form-group">
          <label class="form-label" for="pkg-duration">Duration</label>
          <select id="pkg-duration" class="form-input">
            <option>3–5 Days</option>
            <option>7 Days</option>
            <option>10 Days</option>
            <option>14+ Days</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="pkg-travellers">Travellers</label>
          <input id="pkg-travellers" type="number" class="form-input" placeholder="2" min="1" value="2" />
        </div>
        <div class="form-group">
          <label class="form-label" for="pkg-budget">Budget</label>
          <select id="pkg-budget" class="form-input">
            <option>Budget</option>
            <option>Mid-range</option>
            <option>Luxury</option>
            <option>Ultra Luxury</option>
          </select>
        </div>
        <button class="booking-btn" id="btn-view-packages">View Packages →</button>
      </form>
      
      <div style="padding: 0.6rem 3rem; font-size:0.7rem; color:rgba(220,232,255,0.3); border-top:1px solid var(--border); text-align:center;">
        <strong style="color:var(--gold-light);">Affiliate Disclosure:</strong> Hotel and transport searches open third-party booking platforms (Booking.com, Uber). Saudi Travel Hub may earn a commission at no extra cost to you. This helps fund our independent editorial work. <a href="/editorial-standards" style="color:var(--gold); text-decoration:underline;">Read our editorial policy</a>.
      </div>
    </div>

    <!-- DESTINATIONS -->
    <section id="destinations" aria-label="Destinations">
      <div class="container">
        <div class="section-header reveal">
          <div class="section-label">Explore the Kingdom</div>
          <h2 class="section-title">Iconic <em>Destinations</em></h2>
          <p class="section-sub">From the neon skylines of Riyadh to the ancient rose-red rocks of AlUla — every corner of Saudi Arabia is a world unto itself.</p>
        </div>
        <div class="destinations-grid reveal">
          <a href="/destinations/riyadh/" class="dest-card dest-riyadh">
            <img class="dest-img" src="https://images.unsplash.com/photo-1586724237569-f3d0c1dee8c6?q=80&w=600" alt="Riyadh skyline — Saudi Arabia capital city" loading="lazy" />
            <div class="dest-bg"></div>
            <div class="dest-overlay"></div>
            <div class="dest-arrow" aria-hidden="true">↗</div>
            <div class="dest-content">
              <div class="dest-category">Capital City · FIFA 2034 Host</div>
              <div class="dest-name">Riyadh</div>
              <div class="dest-desc">The beating heart of the Kingdom — Diriyah, Qiddiya, Kingdom Tower &amp; beyond</div>
            </div>
          </a>

          <a href="/destinations/jeddah/" class="dest-card dest-jeddah">
            <img class="dest-img" src="https://images.unsplash.com/photo-1551047465-91a3c8502f1a?q=80&w=600" alt="Jeddah historic Al-Balad district and Red Sea coast" loading="lazy" />
            <div class="dest-bg"></div>
            <div class="dest-overlay"></div>
            <div class="dest-arrow" aria-hidden="true">↗</div>
            <div class="dest-content">
              <div class="dest-category"><strong>Red Sea Gateway</strong> · UNESCO Heritage</div>
              <div class="dest-name">Jeddah</div>
              <div class="dest-desc"><strong>Al-Balad's coral buildings</strong>, seafront corniche and <strong>world-class diving</strong></div>
            </div>
          </a>

          <a href="/blog/alula-guide" class="dest-card dest-alula">
            <img class="dest-img" src="https://images.unsplash.com/photo-1614728894747-a83421e2b9c9?q=80&w=600" alt="AlUla ancient Nabataean rock tombs and desert landscape" loading="lazy" />
            <div class="dest-bg"></div>
            <div class="dest-overlay"></div>
            <div class="dest-arrow" aria-hidden="true">↗</div>
            <div class="dest-content">
              <div class="dest-category">Ancient Wonder</div>
              <div class="dest-name">AlUla</div>
            </div>
          </a>

          <a href="/destinations/neom/" class="dest-card dest-neom">
            <img class="dest-img" src="https://images.unsplash.com/photo-1507608869274-d3177c8bb4c7?q=80&w=600" alt="NEOM futuristic city development in Saudi Arabia" loading="lazy" />
            <div class="dest-bg"></div>
            <div class="dest-overlay"></div>
            <div class="dest-arrow" aria-hidden="true">↗</div>
            <div class="dest-content">
              <div class="dest-category">Future City</div>
              <div class="dest-name">NEOM</div>
            </div>
          </a>

          <a href="/destinations/abha/" class="dest-card dest-abha">
            <img class="dest-img" src="https://images.unsplash.com/photo-1616166308003-8b7ff036109e?q=80&w=600" alt="Abha mountain cityscape in the Asir region" loading="lazy" />
            <div class="dest-bg"></div>
            <div class="dest-overlay"></div>
            <div class="dest-arrow" aria-hidden="true">↗</div>
            <div class="dest-content">
              <div class="dest-category">Mountain Escape · FIFA 2034 Host</div>
              <div class="dest-name">Abha</div>
            </div>
          </a>

          <a href="/destinations/al-khobar/" class="dest-card dest-khobar">
            <img class="dest-img" src="https://images.unsplash.com/photo-1608958416700-1c640d170560?q=80&w=600" alt="Al Khobar waterfront on the Arabian Gulf" loading="lazy" />
            <div class="dest-bg"></div>
            <div class="dest-overlay"></div>
            <div class="dest-arrow" aria-hidden="true">↗</div>
            <div class="dest-content">
              <div class="dest-category">Eastern Province · FIFA 2034 Host</div>
              <div class="dest-name">Al Khobar</div>
            </div>
          </a>

          <a href="/destinations/tabuk/" class="dest-card dest-tabuk">
            <img class="dest-img" src="https://images.unsplash.com/photo-1596120228308-2c3475d9e5a1?q=80&w=600" alt="Tabuk region scenery in northwest Saudi Arabia" loading="lazy" />
            <div class="dest-bg"></div>
            <div class="dest-overlay"></div>
            <div class="dest-arrow" aria-hidden="true">↗</div>
            <div class="dest-content">
              <div class="dest-category">Red Sea North</div>
              <div class="dest-name">Tabuk</div>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- FIFA 2034 BAND -->
    <div class="fifa-band" id="fifa" role="region" aria-label="FIFA World Cup 2034">
      <div class="fifa-inner">
        <div class="fifa-content reveal">
          <div class="section-label">World Cup 2034</div>
          <h2 class="fifa-title">
            The World Comes<br />
            <strong>to Saudi Arabia</strong>
          </h2>
          <p class="fifa-desc">The <strong>FIFA World Cup 2034</strong> crowns Saudi Arabia as the global stage for football's greatest spectacle. <strong>15 iconic stadiums</strong>, <strong>8 host cities</strong>, and millions of fans — plan your experience now.</p>
          <div style="display:flex;gap:1rem;flex-wrap:wrap;">
            <a href="/fifa-2034-tickets" class="btn-primary">Book FIFA Tickets</a>
            <a href="/fifa-2034/stadiums/" class="btn-outline">View All Stadiums</a>
          </div>
          <div class="fifa-cards" style="margin-top:2.5rem;">
            <div class="fifa-card">
              <div class="fifa-card-icon" style="background-image: url('https://images.unsplash.com/photo-1577223625816-7546f13df25d?q=80&w=400');" role="img" aria-label="Stadium icon"></div>
              <div class="fifa-card-title">15 Stadiums</div>
              <div class="fifa-card-val">Across 5 cities</div>
            </div>
            <div class="fifa-card">
              <div class="fifa-card-icon" style="background-image: url('https://images.unsplash.com/photo-1574629810360-7efbbe195018?q=80&w=400');" role="img" aria-label="Teams icon"></div>
              <div class="fifa-card-title">48 Teams</div>
              <div class="fifa-card-val">104 matches</div>
            </div>
            <div class="fifa-card">
              <div class="fifa-card-icon" style="background-image: url('https://images.unsplash.com/photo-1551958219-acbc608c6377?q=80&w=400');" role="img" aria-label="Fans icon"></div>
              <div class="fifa-card-title">3.5M+ Fans</div>
              <div class="fifa-card-val">Expected visitors</div>
            </div>
            <div class="fifa-card">
              <div class="fifa-card-icon" style="background-image: url('https://images.unsplash.com/photo-1506784365847-bbad939e9335?q=80&w=400');" role="img" aria-label="Calendar icon"></div>
              <div class="fifa-card-title">Nov–Dec 2034</div>
              <div class="fifa-card-val">Perfect weather</div>
            </div>
          </div>
        </div>

        <div class="fifa-visual reveal reveal-delay-2" id="stadiums">
          <div class="stadium-card">
            <div class="stadium-img-placeholder">
              <img src="https://images.unsplash.com/photo-1522778119026-d647f0596c20?q=80&w=1000" alt="King Salman Stadium, Riyadh — FIFA 2034 Opening and Final venue" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
            </div>
            <div class="stadium-bar"></div>
            <div class="stadium-header">
              <div>
                <div class="stadium-name">King Salman Stadium</div>
                <div class="stadium-city">Riyadh — Opening Ceremony &amp; Final</div>
              </div>
              <div class="stadium-cap">92,760</div>
            </div>
          </div>
          <div class="stadium-card">
            <div class="stadium-img-placeholder">
              <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?q=80&w=1000" alt="NEOM Stadium — suspended above the sea" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
            </div>
            <div class="stadium-bar"></div>
            <div class="stadium-header">
              <div>
                <div class="stadium-name">NEOM Stadium</div>
                <div class="stadium-city">NEOM — Suspended Above Sea</div>
              </div>
              <div class="stadium-cap">46,000</div>
            </div>
          </div>
          <div class="stadium-card">
            <div class="stadium-img-placeholder">
              <img src="https://images.unsplash.com/photo-1577223625816-7546f13df25d?q=80&w=1000" alt="King Abdullah Sports City, Jeddah — The Shining Jewel stadium" loading="lazy" style="width:100%;height:100%;object-fit:cover;" />
            </div>
            <div class="stadium-bar"></div>
            <div class="stadium-header">
              <div>
                <div class="stadium-name">King Abdullah Sports City</div>
                <div class="stadium-city">Jeddah — The Shining Jewel</div>
              </div>
              <div class="stadium-cap">62,241</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- EXPERIENCES -->
    <section class="experiences-section" id="experiences" aria-label="Experiences in Saudi Arabia">
      <div class="container">
        <div class="section-header centered reveal">
          <div class="section-label">What Awaits You</div>
          <h2 class="section-title">Extraordinary <em>Experiences</em></h2>
