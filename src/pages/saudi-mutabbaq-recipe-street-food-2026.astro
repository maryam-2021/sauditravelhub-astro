---
// src/pages/saudi-mutabbaq-recipe-street-food-2026.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Authentic Saudi Mutabbaq Recipe: Crispy Stuffed Flatbread" 
  description="Master the crispy, pan-fried street food classic with our step-by-step Mutabbaq recipe. Stuffed with savory spiced meat, eggs, and leeks."
  canonicalUrl="https://www.sauditravelhub.com/saudi-mutabbaq-recipe-street-food-2026/"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": "What does Mutabbaq mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mutabbaq literally means 'folded' in Arabic. It is a thin flatbread dough folded around a filling and pan-fried until crispy."
      }
    }, {
      "@type": "Question",
      "name": "What is Mutabbaq stuffed with?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The classic savory Mutabbaq is stuffed with spiced minced beef or lamb, whisked eggs, chopped leeks, green onions, and cumin. Sweet versions are stuffed with banana and honey or sweet cheese."
      }
    }]
  }
  </script>

  <main id="main-content" style="max-width: 800px; margin: 0 auto; padding: 7rem 1.5rem 3rem; font-family: 'Outfit', sans-serif; line-height: 1.8; color: var(--white);">
    <!-- HERO SECTION -->
    <header style="margin-bottom: 3rem; text-align: center;">
      <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold); font-weight: 700; margin-bottom: 0.75rem;">Cuisine &amp; Dining · Street Food</div>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.75rem; line-height: 1.2; margin-bottom: 1.5rem; font-weight: 700; color: #fff;">Saudi Mutabbaq: Crispy Stuffed Flatbread Recipe</h1>
      
      <div style="position: relative; border-radius: 12px; overflow: hidden; margin-top: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.3); border: 1px solid var(--border);">
        <img src="/images/saudi_street_food_mutabbaq.webp" alt="Saudi Mutabbaq crispy folded street food pastry" loading="lazy" style="width: 100%; height: auto; display: block; max-height: 450px; object-fit: cover;" / width="400" height="300" decoding="async" />
        <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(5,13,26,0.95) 0%, rgba(5,13,26,0.5) 60%, transparent 100%); padding: 1.5rem 2rem; text-align: left;">
          <p style="color: var(--white); font-size: 0.95rem; margin: 0; font-style: italic; font-weight: 500; text-shadow: 1px 1px 3px rgba(0,0,0,0.95);">Crispy folded pastry filled with spiced meat, egg and spring onion. Al-Balad's most beloved street snack.</p>
        </div>
      </div>
    </header>

    <!-- TABS NAVIGATION -->
    <div class="tabs-nav" style="display: flex; gap: 0.5rem; border-bottom: 2px solid var(--border); margin-bottom: 2rem; justify-content: center; flex-wrap: wrap;">
      <button class="tab-btn active" data-tab="recipe" style="background: none; border: none; border-bottom: 2px solid var(--gold); padding: 0.75rem 1.5rem; color: #fff; font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">Recipe / Guide</button>
      <button class="tab-btn" data-tab="background" style="background: none; border: none; border-bottom: 2px solid transparent; padding: 0.75rem 1.5rem; color: var(--white-dim); font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">Background &amp; Origin</button>
      <button class="tab-btn" data-tab="recent" style="background: none; border: none; border-bottom: 2px solid transparent; padding: 0.75rem 1.5rem; color: var(--white-dim); font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">Recent Blogs</button>
    </div>

    <!-- TABS CONTENT -->
    <div class="tab-content" id="tab-recipe" style="display: block;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--gold); margin-bottom: 1.25rem; font-weight: 700;">Savory Saudi Mutabbaq Recipe</h2>
      <p style="margin-bottom: 1.5rem;">This recipe shows you how to make crispy, savory Mutabbaq using spring roll wrappers or phyllo pastry sheets, which are a popular, easy hack for getting the perfect thin, flaky texture at home.</p>
      
      <div style="background: var(--surface2); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 2rem;">
        <h4 style="color: var(--gold); font-size: 1.2rem; margin-bottom: 1rem; font-weight: 700;">Recipe Details</h4>
        <ul style="list-style-type: none; padding-left: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; font-size: 1rem;">
          <li>⏰ <strong>Prep Time:</strong> 20 mins</li>
          <li>🍳 <strong>Cook Time:</strong> 15 mins</li>
          <li>🍽️ <strong>Servings:</strong> 4 servings</li>
          <li>🔥 <strong>Difficulty:</strong> Easy</li>
        </ul>
      </div>

      <h3 style="font-size: 1.4rem; color: #fff; margin-bottom: 0.75rem; font-weight: 600;">Ingredients</h3>
      <ul style="padding-left: 1.5rem; margin-bottom: 2rem; list-style-type: square;">
        <li style="margin-bottom: 0.5rem;">1 pack of large spring roll pastry sheets (or phyllo pastry)</li>
        <li style="margin-bottom: 0.5rem;">300g minced beef or lamb</li>
        <li style="margin-bottom: 0.5rem;">3 eggs (whisked)</li>
        <li style="margin-bottom: 0.5rem;">1 cup leeks or green onions (very finely chopped)</li>
        <li style="margin-bottom: 0.5rem;">1/2 cup tomato (deseeded and finely diced)</li>
        <li style="margin-bottom: 0.5rem;">1 onion (finely chopped)</li>
        <li style="margin-bottom: 0.5rem;"><strong>Spices:</strong> 1 tsp cumin, 1 tsp coriander powder, 1/2 tsp black pepper, salt to taste.</li>
        <li style="margin-bottom: 0.5rem;">Garnish: Fresh lemon wedges and green chili peppers.</li>
      </ul>

      <h3 style="font-size: 1.4rem; color: #fff; margin-bottom: 0.75rem; font-weight: 600;">Step-by-Step Instructions</h3>
      <ol style="padding-left: 1.5rem; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.75rem;">
        <li>1. <strong>Cook Meat Filling:</strong> In a frying pan, cook minced onions with a little oil. Add the minced beef or lamb, cumin, coriander, salt, and pepper. Sauté until meat is completely browned. Let it cool slightly.</li>
        <li>2. <strong>Prepare Egg Mixture:</strong> In a bowl, beat the eggs. Stir in the chopped leeks (or green onions), diced tomatoes, and the cooled, cooked meat. Mix well.</li>
        <li>3. <strong>Assemble Mutabbaq:</strong> Lay a pastry sheet flat on a clean board. Place 3 to 4 tablespoons of the filling mixture right in the center of the sheet.</li>
        <li>4. <strong>Fold into Squares:</strong> Fold the left and right sides of the sheet over the filling, then fold the top and bottom sides over, sealing the filling inside to form a flat square pocket. Use a little beaten egg on the edges to stick them securely.</li>
        <li>5. <strong>Pan-Fry:</strong> Heat a flat griddle or wide skillet on medium-high heat. Add 1 tablespoon of oil. Carefully place the folded Mutabbaq seam-side down. Fry for 3-4 minutes until crispy and golden brown, then flip and fry the other side.</li>
        <li>6. <strong>Serve:</strong> Slice the Mutabbaq into small squares. Serve immediately while hot and crispy with fresh lemon wedges to squeeze on top, and small green chilies on the side.</li>
      </ol>
    </div>

    <div class="tab-content" id="tab-background" style="display: none;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--gold); margin-bottom: 1.25rem; font-weight: 700;">Jeddah's Most Beloved Street Snack</h2>
      <p style="margin-bottom: 1.5rem;">Mutabbaq is the king of street food in the western Hijaz region of Saudi Arabia. If you walk the historic cobblestone alleys of Al-Balad in Jeddah after sunset, the air is thick with the scent of Mutabbaq being sizzled on large, flat iron griddles by street vendors.</p>
      
      <p style="margin-bottom: 1.5rem;"><strong>A Trade Route Adaptation:</strong> The word "Mutabbaq" literally translates to "folded" in Arabic. Its history is closely linked to Saudi Arabia's maritime trade across the Indian Ocean. It is the Arabian cousin of the South Asian *Murtabak* and the Southeast Asian *Martabak*. As traders and pilgrims traveled through the port of Jeddah, the recipe was adapted using local Bedouin spices (cumin, coriander) and Hijazi leeks, creating a unique local flavor.</p>

      <p style="margin-bottom: 2rem;"><strong>Modern Varieties:</strong> While the savory minced-meat Mutabbaq is the most common, Saudi street food stalls offer sweet versions that are highly popular. You can order a sweet Mutabbaq stuffed with mashed bananas, cream, and drizzled with honey, or filled with sweet local cream cheese (Jibnah). It represents the vibrant, multicultural food culture of Jeddah.</p>
    </div>

    <div class="tab-content" id="tab-recent" style="display: none;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--gold); margin-bottom: 1.5rem; font-weight: 700;">Explore More Saudi Food Guides</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <a href="/saudi-arabia-traditional-food-guide-15-dishes/" style="display: block; padding: 1rem 1.5rem; border: 1px solid var(--border); border-radius: 8px; background: var(--surface2); color: #fff; text-decoration: none; transition: border-color 0.3s ease;">
          <strong style="color: var(--gold); display: block; font-size: 1.1rem;">📖 15 Traditional Saudi Dishes &rarr;</strong>
          <span style="font-size: 0.9rem; color: var(--white-dim);">Compare all the major rice, meat, street food, and dessert options in the Kingdom.</span>
        </a>
        <a href="/saudi-kabsa-recipe-traditional-guide-2026/" style="display: block; padding: 1rem 1.5rem; border: 1px solid var(--border); border-radius: 8px; background: var(--surface2); color: #fff; text-decoration: none; transition: border-color 0.3s ease;">
          <strong style="color: var(--gold); display: block; font-size: 1.1rem;">🍗 Traditional Saudi Kabsa Recipe &rarr;</strong>
          <span style="font-size: 0.9rem; color: var(--white-dim);">Learn to make the famous national chicken and saffron rice dish.</span>
        </a>
        <a href="/saudi-red-sea-seafood-guide-2026/" style="display: block; padding: 1rem 1.5rem; border: 1px solid var(--border); border-radius: 8px; background: var(--surface2); color: #fff; text-decoration: none; transition: border-color 0.3s ease;">
          <strong style="color: var(--gold); display: block; font-size: 1.1rem;">🐟 Red Sea Seafood Culinary Guide &rarr;</strong>
          <span style="font-size: 0.9rem; color: var(--white-dim);">Explore Jeddah's fresh hammour, lobster, and king prawns.</span>
        </a>
      </div>
    </div>
  </main>

  <script slot="body">
    const buttons = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => {
          b.classList.remove('active');
          b.style.borderBottomColor = 'transparent';
          b.style.color = 'var(--white-dim)';
        });
        contents.forEach(c => c.style.display = 'none');
        btn.classList.add('active');
        btn.style.borderBottomColor = 'var(--gold)';
        btn.style.color = '#fff';
        const target = document.getElementById(`tab-${btn.dataset.tab}`);
        target.style.display = 'block';
      });
    });
  </script>
</Layout>

<style>
  .tab-btn.active {
    border-bottom: 2px solid var(--gold) !important;
    color: #fff !important;
  }
</style>
