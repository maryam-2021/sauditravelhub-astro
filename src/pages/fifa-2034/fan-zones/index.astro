---
// src/pages/fifa-2034/fan-zones/index.astro
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="FIFA 2034 Fan Zones Saudi Arabia | Saudi Travel Hub"
  description="Discover the official FIFA 2034 Fan Zones across Saudi Arabia's host cities. Sign up for alerts when fan zone locations, opening hours, and programming are announced."
  canonicalUrl="https://www.sauditravelhub.com/fifa-2034/fan-zones/"
>
  <main id="main-content" style="min-height: 80vh; background: var(--black);">

    <!-- HERO BAND -->
    <section style="padding: 8rem 3rem 5rem; background: linear-gradient(135deg, #050d1a 0%, #0a1628 60%, #050d1a 100%); border-bottom: 1px solid var(--border); text-align: center; position: relative; overflow: hidden;">
      <!-- Background watermark -->
      <div aria-hidden="true" style="position:absolute; right:-2%; top:50%; transform:translateY(-50%); font-family:'Cormorant Garamond',serif; font-size:22vw; font-weight:700; color:rgba(201,168,76,0.04); line-height:1; pointer-events:none; letter-spacing:-0.05em;">2034</div>

      <div style="position:relative; z-index:2; max-width:700px; margin:0 auto;">
        <div style="display:inline-flex; align-items:center; gap:0.5rem; border:1px solid rgba(201,168,76,0.4); background:rgba(201,168,76,0.08); padding:0.4rem 1.1rem; border-radius:100px; font-size:0.78rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--gold-light); margin-bottom:2rem;">
          <span style="width:6px; height:6px; background:var(--gold); border-radius:50; animation:pulse 2s ease infinite;"></span>
          Coming Soon — FIFA 2034
        </div>
        <h1 style="font-family:'Cormorant Garamond',serif; font-size:clamp(2.5rem,6vw,4.5rem); font-weight:300; line-height:1.1; margin-bottom:1.5rem;">
          FIFA 2034 <em style="color:var(--gold);">Fan Zones</em>
        </h1>
        <p style="font-size:1.05rem; color:var(--white-dim); max-width:580px; margin:0 auto 2.5rem; line-height:1.8;">
          Official fan zones will be set up across all eight FIFA 2034 host cities — including Riyadh, Jeddah, NEOM, Abha, and Al Khobar. These free-entry public spaces will host live match screenings, cultural performances, food markets, and interactive football experiences.
        </p>
        <p style="font-size:0.9rem; color:var(--gold); font-weight:600;">
          Exact locations and programming will be announced by FIFA and Saudi authorities in 2033. Sign up below to be the first to know.
        </p>
      </div>
    </section>

    <!-- WHAT TO EXPECT SECTION -->
    <section style="padding: 5rem 3rem; background: var(--surface);">
      <div style="max-width: 1000px; margin: 0 auto;">
        <div style="font-size:0.72rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--gold); font-weight:600; margin-bottom:0.8rem; display:flex; align-items:center; gap:0.7rem;">
          <span style="display:block; width:28px; height:1px; background:var(--gold);"></span>
          What to Expect
        </div>
        <h2 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.8rem,3vw,2.8rem); font-weight:300; margin-bottom:3rem;">
          Fan Zones Across <em style="color:var(--gold);">8 Host Cities</em>
        </h2>

        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:1.5rem;">
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">📺</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">Live Match Screenings</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Watch every FIFA 2034 match on giant outdoor screens, free for all fans, alongside thousands of supporters from around the world.</p>
          </div>
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">🎭</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">Cultural Performances</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Ardah sword dances, live Arabic music, and regional performances celebrating Saudi culture alongside international World Cup entertainment.</p>
          </div>
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">🍖</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">Food & Markets</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Saudi street food, international cuisines, and authentic Kabsa and Mandi served alongside global fan favourites in a festive marketplace.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- EMAIL SIGNUP SECTION -->
    <section style="padding: 5rem 3rem; background: var(--deep); text-align: center;">
      <div style="max-width: 560px; margin: 0 auto;">
        <h2 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.8rem,3vw,2.5rem); font-weight:300; margin-bottom:1rem;">
          Be the First to Know
        </h2>
        <p style="color:var(--white-dim); font-size:0.95rem; margin-bottom:2.5rem; line-height:1.7;">
          Get notified the moment FIFA 2034 Fan Zone locations, city guides, and free-entry details are officially announced.
        </p>
        <form
          id="fanzones-signup"
          onsubmit="return false;"
          style="display:flex; gap:0; max-width:480px; margin:0 auto 1rem;"
          aria-label="Fan zone alerts signup"
        >
          <label for="fanzones-email" style="position:absolute;left:-9999px;">Email address</label>
          <input
            type="email"
            id="fanzones-email"
            placeholder="your@email.com"
            autocomplete="email"
            required
            style="flex:1; background:var(--surface); border:1px solid var(--border); border-right:none; color:var(--white); padding:0.9rem 1.2rem; font-family:'Outfit',sans-serif; font-size:0.9rem; outline:none; border-radius:var(--radius) 0 0 var(--radius);"
          />
          <button
            type="submit"
            id="fanzones-submit"
            style="background:linear-gradient(135deg,var(--gold),var(--gold-light)); color:var(--black); border:none; padding:0.9rem 1.6rem; font-family:'Outfit',sans-serif; font-weight:700; font-size:0.85rem; letter-spacing:0.08em; text-transform:uppercase; border-radius:0 var(--radius) var(--radius) 0; cursor:pointer; white-space:nowrap;"
          >
            Alert Me →
          </button>
        </form>
        <p id="fanzones-msg" role="alert" aria-live="polite" style="font-size:0.82rem; min-height:1.2em; margin-top:0.5rem;"></p>
        <p style="font-size:0.72rem; color:rgba(245,240,232,0.3); margin-top:0.5rem;">No spam. Unsubscribe anytime. Read our <a href="/privacy/" style="color:var(--gold);">Privacy Policy</a>.</p>
      </div>
    </section>

    <!-- BACK LINK -->
    <div style="padding:2rem 3rem; text-align:center; border-top:1px solid var(--border);">
      <a href="/fifa-2034/" style="color:var(--gold); font-size:0.85rem; font-weight:600; text-decoration:none; letter-spacing:0.06em; text-transform:uppercase;">← Back to FIFA 2034 Guide</a>
    </div>

  </main>
</Layout>

<script>
  const btn = document.getElementById('fanzones-submit');
  const input = document.getElementById('fanzones-email') as HTMLInputElement;
  const msg = document.getElementById('fanzones-msg');

  btn?.addEventListener('click', () => {
    const email = input?.value?.trim();
    if (!email || !email.includes('@') || !email.includes('.')) {
      if (msg) { msg.textContent = 'Please enter a valid email address.'; msg.style.color = '#c0392b'; }
      return;
    }
    if (msg) {
      msg.textContent = `✓ You're on the list! We'll alert ${email} when Fan Zone details drop.`;
      msg.style.color = 'var(--gold)';
    }
    if (input) input.value = '';
  });
</script>
