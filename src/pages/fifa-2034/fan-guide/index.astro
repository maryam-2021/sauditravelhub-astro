---
// src/pages/fifa-2034/fan-guide/index.astro
import Layout from '../../../layouts/Layout.astro';
---

<Layout
  title="FIFA 2034 Fan Guide Saudi Arabia | Saudi Travel Hub"
  description="Your complete fan guide to attending the FIFA World Cup 2034 in Saudi Arabia. Practical tips on culture, dress code, transport, currency, and stadium etiquette."
  canonicalUrl="https://www.sauditravelhub.com/fifa-2034/fan-guide/"
>
  <main id="main-content" style="min-height: 80vh; background: var(--black);">

    <!-- HERO BAND -->
    <section style="padding: 8rem 3rem 5rem; background: linear-gradient(135deg, #050d1a 0%, #0a1628 60%, #050d1a 100%); border-bottom: 1px solid var(--border); text-align: center; position: relative; overflow: hidden;">
      <div aria-hidden="true" style="position:absolute; right:-2%; top:50%; transform:translateY(-50%); font-family:'Cormorant Garamond',serif; font-size:22vw; font-weight:700; color:rgba(201,168,76,0.04); line-height:1; pointer-events:none; letter-spacing:-0.05em;">2034</div>

      <div style="position:relative; z-index:2; max-width:700px; margin:0 auto;">
        <div style="display:inline-flex; align-items:center; gap:0.5rem; border:1px solid rgba(201,168,76,0.4); background:rgba(201,168,76,0.08); padding:0.4rem 1.1rem; border-radius:100px; font-size:0.78rem; font-weight:500; letter-spacing:0.1em; text-transform:uppercase; color:var(--gold-light); margin-bottom:2rem;">
          <span style="width:6px; height:6px; background:var(--gold); border-radius:50%;"></span>
          Full Guide Coming 2033
        </div>
        <h1 style="font-family:'Cormorant Garamond',serif; font-size:clamp(2.5rem,6vw,4.5rem); font-weight:300; line-height:1.1; margin-bottom:1.5rem;">
          FIFA 2034 <em style="color:var(--gold);">Fan Guide</em>
        </h1>
        <p style="font-size:1.05rem; color:var(--white-dim); max-width:580px; margin:0 auto 2.5rem; line-height:1.8;">
          Everything a visiting fan needs to know about attending the 2034 FIFA World Cup in Saudi Arabia — from cultural essentials and dress code to stadium access, payment methods, and getting around the Kingdom.
        </p>
        <p style="font-size:0.9rem; color:var(--gold); font-weight:600;">
          Our comprehensive fan guide is being developed now. Sign up to receive it the moment it publishes.
        </p>
      </div>
    </section>

    <!-- QUICK TIPS SECTION -->
    <section style="padding: 5rem 3rem; background: var(--surface);">
      <div style="max-width: 1000px; margin: 0 auto;">
        <div style="font-size:0.72rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--gold); font-weight:600; margin-bottom:0.8rem; display:flex; align-items:center; gap:0.7rem;">
          <span style="display:block; width:28px; height:1px; background:var(--gold);"></span>
          Start Planning Now
        </div>
        <h2 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.8rem,3vw,2.8rem); font-weight:300; margin-bottom:3rem;">
          Essential <em style="color:var(--gold);">Fan Tips</em>
        </h2>

        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px,1fr)); gap:1.5rem;">
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">🪪</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">eVisa Required</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Most nationalities need a Saudi eVisa. It takes under 5 minutes to apply online via the official Visit Saudi portal. Special FIFA 2034 fan ID cards may be introduced closer to the tournament.</p>
            <a href="/visa-guide/" style="display:inline-block; margin-top:1rem; color:var(--gold); font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; text-decoration:none;">Visa Guide →</a>
          </div>
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">👗</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">Dress Respectfully</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Saudi Arabia has relaxed dress rules for tourists significantly. Cover shoulders and knees in public areas outside stadiums. Team jerseys and fan gear are encouraged at match venues.</p>
            <a href="/what-to-wear-saudi-arabia-women-dress-code-2026/" style="display:inline-block; margin-top:1rem; color:var(--gold); font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; text-decoration:none;">Dress Code Guide →</a>
          </div>
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">💳</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">Cashless & Card-Friendly</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Visa and Mastercard are accepted almost everywhere. Apple Pay and contactless payment are widely available. The Saudi Riyal (SAR) is pegged to the US dollar at approximately 3.75 SAR to $1.</p>
          </div>
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">🚇</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">Metro & Transport</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Riyadh Metro connects to King Fahd Stadium via Line 2. Jeddah, NEOM, and other host cities will have match-day shuttle services. Use Uber or Careem for on-demand rides across all cities.</p>
            <a href="/travel-guide/getting-around/" style="display:inline-block; margin-top:1rem; color:var(--gold); font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; text-decoration:none;">Transport Guide →</a>
          </div>
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">🌡️</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">November–December: Perfect Weather</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">The 2034 World Cup will run Nov–Dec, Saudi Arabia's coolest months. Riyadh averages 20–28°C daytime, dropping pleasantly at night. Coastal cities like Jeddah are warmer and humid.</p>
            <a href="/fifa-2034/weather/" style="display:inline-block; margin-top:1rem; color:var(--gold); font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; text-decoration:none;">Weather Guide →</a>
          </div>
          <div style="background:var(--surface2); border:1px solid var(--border); border-radius:var(--radius-lg); padding:1.8rem;">
            <div style="color:var(--gold); font-size:1.8rem; margin-bottom:1rem;">🔒</div>
            <h3 style="font-size:1rem; font-weight:600; margin-bottom:0.5rem;">Very Safe for Fans</h3>
            <p style="font-size:0.85rem; color:var(--white-dim); line-height:1.6;">Saudi Arabia consistently ranks among the world's safest countries (Numbeo 2026: 98% safety rating). Petty crime is rare and security at major events is world-class.</p>
            <a href="/travel-guide/safety/" style="display:inline-block; margin-top:1rem; color:var(--gold); font-size:0.8rem; font-weight:600; text-transform:uppercase; letter-spacing:0.06em; text-decoration:none;">Safety Guide →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- EMAIL SIGNUP SECTION -->
    <section style="padding: 5rem 3rem; background: var(--deep); text-align: center;">
      <div style="max-width: 560px; margin: 0 auto;">
        <h2 style="font-family:'Cormorant Garamond',serif; font-size:clamp(1.8rem,3vw,2.5rem); font-weight:300; margin-bottom:1rem;">
          Get the Full Fan Guide
        </h2>
        <p style="color:var(--white-dim); font-size:0.95rem; margin-bottom:2.5rem; line-height:1.7;">
          We're building the most comprehensive FIFA 2034 fan guide available — covering every host city, stadium, hotel zone, and cultural essential. Be first to receive it.
        </p>
        <form
          id="fanguide-signup"
          onsubmit="return false;"
          style="display:flex; gap:0; max-width:480px; margin:0 auto 1rem;"
          aria-label="Fan guide signup"
        >
          <label for="fanguide-email" style="position:absolute;left:-9999px;">Email address</label>
          <input
            type="email"
            id="fanguide-email"
            placeholder="your@email.com"
            autocomplete="email"
            required
            style="flex:1; background:var(--surface); border:1px solid var(--border); border-right:none; color:var(--white); padding:0.9rem 1.2rem; font-family:'Outfit',sans-serif; font-size:0.9rem; outline:none; border-radius:var(--radius) 0 0 var(--radius);"
          />
          <button
            type="submit"
            id="fanguide-submit"
            style="background:linear-gradient(135deg,var(--gold),var(--gold-light)); color:var(--black); border:none; padding:0.9rem 1.6rem; font-family:'Outfit',sans-serif; font-weight:700; font-size:0.85rem; letter-spacing:0.08em; text-transform:uppercase; border-radius:0 var(--radius) var(--radius) 0; cursor:pointer; white-space:nowrap;"
          >
            Send Me the Guide →
          </button>
        </form>
        <p id="fanguide-msg" role="alert" aria-live="polite" style="font-size:0.82rem; min-height:1.2em; margin-top:0.5rem;"></p>
        <p style="font-size:0.72rem; color:rgba(245,240,232,0.3); margin-top:0.5rem;">No spam. Unsubscribe anytime. Read our <a href="/privacy/" style="color:var(--gold);">Privacy Policy</a>.</p>
      </div>
    </section>

    <!-- BACK LINK -->
    <div style="padding:2rem 3rem; text-align:center; border-top:1px solid var(--border);">
      <a href="/fifa-2034/" style="color:var(--gold); font-size:0.85rem; font-weight:600; text-decoration:none; letter-spacing:0.06em; text-transform:uppercase;">← Back to FIFA 2034 Guide</a>
    </div>

  </main>
</Layout>

<script>
  const btn = document.getElementById('fanguide-submit');
  const input = document.getElementById('fanguide-email') as HTMLInputElement;
  const msg = document.getElementById('fanguide-msg');

  btn?.addEventListener('click', () => {
    const email = input?.value?.trim();
    if (!email || !email.includes('@') || !email.includes('.')) {
      if (msg) { msg.textContent = 'Please enter a valid email address.'; msg.style.color = '#c0392b'; }
      return;
    }
    if (msg) {
      msg.textContent = `✓ Done! We'll send the full FIFA 2034 fan guide to ${email} when it's ready.`;
      msg.style.color = 'var(--gold)';
    }
    if (input) input.value = '';
  });
</script>
