  <main id="main-content" style="max-width: 850px; margin: 0 auto; padding: 7rem 1.5rem 3rem; font-family: 'Outfit', sans-serif; line-height: 1.8; color: var(--white);">
    <!-- HERO SECTION -->
    <header style="margin-bottom: 3.5rem; text-align: center;">
      <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold); font-weight: 700; margin-bottom: 0.75rem;">Accommodation &amp; Logistics · FIFA 2034 Guide</div>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.75rem; line-height: 1.2; margin-bottom: 1.5rem; font-weight: 700; color: #fff;">Best Hotels Near King Fahd Stadium Riyadh: 2026 Guide</h1>
      
      <div style="position: relative; border-radius: 12px; overflow: hidden; margin-top: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.3); border: 1px solid var(--border);">
        <img 
          src="/images/luxury_hotel_room_madinah.webp" 
          alt="Luxury hotel room accommodation and premium hospitality in Riyadh" 
          loading="lazy"
