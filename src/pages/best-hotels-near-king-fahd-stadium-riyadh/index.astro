              <th style="padding: 1rem; color: var(--gold); font-weight: 600; text-transform: uppercase;">Rating</th>
              <th style="padding: 1rem; color: var(--gold); font-weight: 600; text-transform: uppercase;">Distance to Stadium</th>
              <th style="padding: 1rem; color: var(--gold); font-weight: 600; text-transform: uppercase;">Key Features</th>
              <th style="padding: 1rem; color: var(--gold); font-weight: 600; text-transform: uppercase;">Best Suited For</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 1rem; font-weight: 700; color: #fff;">Four Seasons Riyadh</td>
