              <td style="padding: 1rem;">Indoor pool, palace grounds, bowling</td>
              <td style="padding: 1rem;">VIP families and delegates</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 1rem; font-weight: 700; color: #fff;">Hilton Riyadh Olaya</td>
              <td style="padding: 1rem;">4-Star Premium</td>
              <td style="padding: 1rem;">5 Min Drive</td>
              <td style="padding: 1rem;">Business lounge, close to metro</td>
              <td style="padding: 1rem;">Business travelers and active fans</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 1rem; font-weight: 700; color: #fff;">Courtyard Marriott Olaya</td>
