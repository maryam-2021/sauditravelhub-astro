---
// src/pages/saudi-kabsa-recipe-traditional-guide-2026.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Traditional Saudi Kabsa Recipe & Cultural Guide 2026" 
  description="Learn how to make authentic Saudi Kabsa. Step-by-step recipe, ingredients, and the cultural history behind Saudi Arabia's national rice and chicken dish."
  canonicalUrl="https://www.sauditravelhub.com/saudi-kabsa-recipe-traditional-guide-2026/"
>
  <script slot="head" type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": "What is the national dish of Saudi Arabia?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Kabsa is the official national dish of Saudi Arabia. It is a flavorful, one-pot dish of spiced basmati rice and slow-cooked meat (usually chicken or lamb) served communally."
      }
    }, {
      "@type": "Question",
      "name": "Can I make Kabsa with chicken?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, chicken (Al-Kabsa bil Dajaj) is the most common and popular variation of Kabsa cooked in Saudi households and restaurants."
      }
    }]
  }
  </script>

  <main id="main-content" style="max-width: 800px; margin: 0 auto; padding: 7rem 1.5rem 3rem; font-family: 'Outfit', sans-serif; line-height: 1.8; color: var(--white);">
    <!-- HERO SECTION -->
    <header style="margin-bottom: 3rem; text-align: center;">
      <div style="font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--gold); font-weight: 700; margin-bottom: 0.75rem;">Cuisine &amp; Dining · National Dish</div>
      <h1 style="font-family: 'Cormorant Garamond', serif; font-size: 2.75rem; line-height: 1.2; margin-bottom: 1.5rem; font-weight: 700; color: #fff;">Traditional Saudi Kabsa Recipe &amp; Guide 2026</h1>
      
      <div style="position: relative; border-radius: 12px; overflow: hidden; margin-top: 2rem; box-shadow: 0 4px 20px rgba(0,0,0,0.3); border: 1px solid var(--border);">
        <img 
          src="/images/saudi_kabsa_platter.webp" 
          alt="Traditional Saudi Kabsa platter with meat and rice" 
          style="width: 100%; height: auto; display: block; max-height: 450px; object-fit: cover;" 
        />
        <div style="position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(to top, rgba(5,13,26,0.95) 0%, rgba(5,13,26,0.5) 60%, transparent 100%); padding: 1.5rem 2rem; text-align: left;">
          <p style="color: var(--white); font-size: 0.95rem; margin: 0; font-style: italic; font-weight: 500; text-shadow: 1px 1px 3px rgba(0,0,0,0.95);">Fragrant saffron rice with slow-cooked chicken, dried fruits and a warm spice blend.</p>
        </div>
      </div>
    </header>

    <!-- TABS NAVIGATION -->
    <div class="tabs-nav" style="display: flex; gap: 0.5rem; border-bottom: 2px solid var(--border); margin-bottom: 2rem; justify-content: center; flex-wrap: wrap;">
      <button class="tab-btn active" data-tab="recipe" style="background: none; border: none; border-bottom: 2px solid var(--gold); padding: 0.75rem 1.5rem; color: #fff; font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">Recipe / Guide</button>
      <button class="tab-btn" data-tab="background" style="background: none; border: none; border-bottom: 2px solid transparent; padding: 0.75rem 1.5rem; color: var(--white-dim); font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">Background &amp; Origin</button>
      <button class="tab-btn" data-tab="recent" style="background: none; border: none; border-bottom: 2px solid transparent; padding: 0.75rem 1.5rem; color: var(--white-dim); font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">Recent Blogs</button>
    </div>

    <!-- TABS CONTENT -->
    <div class="tab-content" id="tab-recipe" style="display: block;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--gold); margin-bottom: 1.25rem; font-weight: 700;">Traditional Chicken Kabsa Recipe</h2>
      <p style="margin-bottom: 1.5rem;">This step-by-step recipe shows you how to make authentic Saudi chicken Kabsa (Kabsa bil Dajaj) at home. Fragrant spices, tender chicken, and perfectly fluffed saffron-infused rice are the keys to this legendary national dish.</p>
      
      <div style="background: var(--surface2); padding: 1.5rem; border-radius: 8px; border: 1px solid var(--border); margin-bottom: 2rem;">
        <h4 style="color: var(--gold); font-size: 1.2rem; margin-bottom: 1rem; font-weight: 700;">Recipe Details</h4>
        <ul style="list-style-type: none; padding-left: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; font-size: 1rem;">
          <li>⏰ <strong>Prep Time:</strong> 20 mins</li>
          <li>🍳 <strong>Cook Time:</strong> 50 mins</li>
          <li>🍽️ <strong>Servings:</strong> 4 to 6 people</li>
          <li>🔥 <strong>Difficulty:</strong> Medium</li>
        </ul>
      </div>

      <h3 style="font-size: 1.4rem; color: #fff; margin-bottom: 0.75rem; font-weight: 600;">Ingredients</h3>
      <ul style="padding-left: 1.5rem; margin-bottom: 2rem; list-style-type: square;">
        <li style="margin-bottom: 0.5rem;">1 whole chicken (cut into pieces) or 1 kg chicken thighs/breasts</li>
        <li style="margin-bottom: 0.5rem;">3 cups basmati rice (washed and soaked for 30 minutes)</li>
        <li style="margin-bottom: 0.5rem;">2 large onions (finely chopped)</li>
        <li style="margin-bottom: 0.5rem;">3 tomatoes (puréed) &amp; 2 tbsp tomato paste</li>
        <li style="margin-bottom: 0.5rem;">4 tbsp ghee or vegetable oil</li>
        <li style="margin-bottom: 0.5rem;"><strong>Kabsa Spice Mix:</strong> 1 tbsp cardamom, 1 cinnamon stick, 4 cloves, 1 tsp cumin, 1 tsp coriander, 1/2 tsp saffron threads, 2 dried black limes (loomi), 3 bay leaves.</li>
        <li style="margin-bottom: 0.5rem;">To garnish: Toasted almonds, pine nuts, and raisins.</li>
      </ul>

      <h3 style="font-size: 1.4rem; color: #fff; margin-bottom: 0.75rem; font-weight: 600;">Step-by-Step Instructions</h3>
      <ol style="padding-left: 1.5rem; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.75rem;">
        <li>1. <strong>Sauté Aromatics:</strong> In a large heavy-bottomed pot, heat ghee or oil. Sauté onions until golden brown. Add whole spices (cinnamon, cloves, cardamom, black lime, bay leaves) and toast until fragrant.</li>
        <li>2. <strong>Cook Chicken:</strong> Add chicken pieces to the pot and sear until lightly browned. Stir in tomato purée, tomato paste, ground cumin, coriander, and salt. Add enough hot water to cover chicken. Simmer for 30 minutes until chicken is tender.</li>
        <li>3. <strong>Roast Chicken:</strong> Pre-heat oven to 200°C (390°F). Remove chicken from broth, place on a baking sheet, brush with a little ghee/saffron water, and roast for 10-15 minutes until golden brown and crispy.</li>
        <li>4. <strong>Cook Rice:</strong> Drain the soaked rice. Measure the remaining chicken broth in the pot (you need about 4.5 cups of liquid for 3 cups of rice). Bring broth to a boil, add rice, cover tightly, and cook on low heat for 15-18 minutes.</li>
        <li>5. <strong>Serve Communally:</strong> Spread the cooked rice onto a large serving platter. Arrange the roasted chicken pieces on top. Garnish generously with toasted almonds, pine nuts, and raisins. Serve immediately with spicy tomato dakous salsa.</li>
      </ol>
    </div>

    <div class="tab-content" id="tab-background" style="display: none;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--gold); margin-bottom: 1.25rem; font-weight: 700;">The Soul of Saudi Cooking</h2>
      <p style="margin-bottom: 1.5rem;">Kabsa is much more than just a meal in Saudi Arabia; it is the ultimate expression of hospitality and communal sharing. In Saudi households, it is traditionally served on a massive round metal tray placed on a floor rug, with family and guests sitting around it to share from the same dish using their right hand.</p>
      
      <p style="margin-bottom: 1.5rem;"><strong>Historical Roots:</strong> Originally a staple Bedouin food, Kabsa was developed to cook rice and meat together in a single pot over an open campfire in the desert. Over time, as trade routes flourished across the Arabian Peninsula, spices from India (basmati rice, cardamom), East Africa (cloves), and Persia (saffron) were integrated into the recipe, turning it into the complex, aromatic masterpiece it is today.</p>

      <p style="margin-bottom: 2rem;"><strong>Regional Variations:</strong> While the basic rice-and-meat structure remains, different regions have their own signature touches. In the coastal Hijaz region, Kabsa is often served with fresh seafood or mutton. In the Najd region (central Saudi Arabia), chicken Kabsa with deep red tomato bases is highly popular. Across all regions, the black dried lime (loomi) remains a vital signature ingredient that cuts through the rich fat of the meat.</p>
    </div>

    <div class="tab-content" id="tab-recent" style="display: none;">
      <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--gold); margin-bottom: 1.5rem; font-weight: 700;">Explore More Saudi Food Guides</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        <a href="/saudi-arabia-traditional-food-guide-15-dishes/" style="display: block; padding: 1rem 1.5rem; border: 1px solid var(--border); border-radius: 8px; background: var(--surface2); color: #fff; text-decoration: none; transition: border-color 0.3s ease;">
          <strong style="color: var(--gold); display: block; font-size: 1.1rem;">📖 15 Traditional Saudi Dishes &rarr;</strong>
          <span style="font-size: 0.9rem; color: var(--white-dim);">Compare all the major rice, meat, street food, and dessert options in the Kingdom.</span>
        </a>
        <a href="/saudi-mutabbaq-recipe-street-food-2026/" style="display: block; padding: 1rem 1.5rem; border: 1px solid var(--border); border-radius: 8px; background: var(--surface2); color: #fff; text-decoration: none; transition: border-color 0.3s ease;">
          <strong style="color: var(--gold); display: block; font-size: 1.1rem;">🥞 Authentic Saudi Mutabbaq Recipe &rarr;</strong>
          <span style="font-size: 0.9rem; color: var(--white-dim);">Learn to make Jeddah's favorite crispy, stuffed pan-fried street food flatbread.</span>
        </a>
        <a href="/saudi-arabic-coffee-gahwa-recipe-guide-2026/" style="display: block; padding: 1rem 1.5rem; border: 1px solid var(--border); border-radius: 8px; background: var(--surface2); color: #fff; text-decoration: none; transition: border-color 0.3s ease;">
          <strong style="color: var(--gold); display: block; font-size: 1.1rem;">☕ Saudi Arabic Coffee (Gahwa) Guide &rarr;</strong>
          <span style="font-size: 0.9rem; color: var(--white-dim);">Discover the spices and traditional welcome rituals behind Saudi hospitality.</span>
        </a>
      </div>
    </div>
  </main>

  <script slot="body">
    const buttons = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => {
          b.classList.remove('active');
          b.style.borderBottomColor = 'transparent';
          b.style.color = 'var(--white-dim)';
        });
        contents.forEach(c => c.style.display = 'none');
        btn.classList.add('active');
        btn.style.borderBottomColor = 'var(--gold)';
        btn.style.color = '#fff';
        const target = document.getElementById(`tab-${btn.dataset.tab}`);
        target.style.display = 'block';
      });
    });
  </script>
</Layout>

<style>
  .tab-btn.active {
    border-bottom: 2px solid var(--gold) !important;
    color: #fff !important;
  }
</style>
