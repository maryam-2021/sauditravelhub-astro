<style>
  /* Header specific additional semantic structures styling */
  .mobile-section-title {
    padding: 1rem 1.5rem 0.2rem;
    color: var(--gold);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
  }
  .mobile-grid-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 0 1rem;
    gap: 0.5rem;
  }
  .mobile-single-links {
    display: grid;
    grid-template-columns: 1fr;
    padding: 0 1rem;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .mobile-grid-links-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 0 1rem;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .mobile-single-links-discover {
    display: grid;
    grid-template-columns: 1fr;
    padding: 0 1.5rem;
    gap: 0.8rem;
  }
  .mobile-divider {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 1rem 1.5rem;
    width: 100%;
  }
</style>

<script>
  // Mobile menu toggle client-side script
  const hamburgerBtn = document.getElementById('hamburgerBtn');
  const mobileCloseBtn = document.getElementById('mobileCloseBtn');
  const mobileMenu = document.getElementById('mobileMenu');

  function toggleMenu() {
    if (mobileMenu && hamburgerBtn) {
      const isOpen = mobileMenu.classList.toggle('open');
      hamburgerBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      document.body.style.overflow = isOpen ? 'hidden' : '';
    }
  }

  if (hamburgerBtn) hamburgerBtn.addEventListener('click', toggleMenu);
  if (mobileCloseBtn) mobileCloseBtn.addEventListener('click', toggleMenu);

  // Close mobile menu on clicking any link
  if (mobileMenu) {
    const mobileLinks = mobileMenu.querySelectorAll('a');
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('open');
        if (hamburgerBtn) hamburgerBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    });
  }

  // Keyboard dropdown support for accessibility
  document.querySelectorAll('.nav-drop-btn').forEach(btn => {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      const parent = this.parentElement;
      const wasExpanded = this.getAttribute('aria-expanded') === 'true';
      
      // Close all other dropdowns
      document.querySelectorAll('.nav-drop').forEach(drop => {
        if (drop !== parent) {
          drop.querySelector('.nav-drop-btn')?.setAttribute('aria-expanded', 'false');
        }
      });

      this.setAttribute('aria-expanded', wasExpanded ? 'false' : 'true');
    });

    btn.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        const content = this.parentElement?.querySelector('.nav-drop-content');
        if (content) {
          const wasExpanded = this.getAttribute('aria-expanded') === 'true';
          this.setAttribute('aria-expanded', wasExpanded ? 'false' : 'true');
          if (!wasExpanded) {
            const firstLink = content.querySelector('a');
            if (firstLink) (firstLink as HTMLElement).focus();
          }
        }
      }
    });
  });

  // Close dropdowns when clicking outside
  document.addEventListener('click', function(e) {
    if (!e.target || !(e.target as HTMLElement).closest('.nav-drop')) {
      document.querySelectorAll('.nav-drop-btn').forEach(btn => {
        btn.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>
