---
// src/components/VerifiedDataPoints.astro
---

<section style="padding: 5rem 3rem; background: var(--surface);" aria-label="Verified facts">
  <div class="container" style="max-width: 1100px;">
    <div class="section-header centered reveal">
      <div class="section-label">✦ Verifiable Facts</div>
      <h2 class="section-title">Trusted by Millions of <em>Visitors</em></h2>
      <p class="section-sub">Factual, government-sourced travel data and safety statistics for Saudi Arabia.</p>
    </div>

    <div class="verified-grid reveal">
      <!-- Card 1: 27M+ Annual Visitors -->
      <div class="verified-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </div>
        <h3 class="stat-number">27M+</h3>
        <p class="stat-title">Annual Visitors</p>
        <p class="stat-description">Saudi Arabia welcomed over 27 million international tourists in 2024 (Source: Ministry of Tourism).</p>
      </div>

      <!-- Card 2: 13 UNESCO Sites -->
      <div class="verified-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" aria-hidden="true">
            <line x1="3" y1="22" x2="21" y2="22"/>
            <line x1="6" y1="18" x2="6" y2="11"/>
            <line x1="10" y1="18" x2="10" y2="11"/>
            <line x1="14" y1="18" x2="14" y2="11"/>
            <line x1="18" y1="18" x2="18" y2="11"/>
            <path d="m12 2 9 5H3L12 2Z"/>
          </svg>
        </div>
        <h3 class="stat-number">13</h3>
        <p class="stat-title">UNESCO Sites</p>
        <p class="stat-description">Home to Hegra, Diriyah, Al-Balad, and more world heritage landmarks.</p>
      </div>

      <!-- Card 3: Official FIFA Host -->
      <div class="verified-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" aria-hidden="true">
            <circle cx="12" cy="12" r="10" />
            <path d="m12 12-4-3 1-4.5h6l1 4.5-4 3Z" />
            <path d="M8 9.5 4 11m8-6.5V2m4 7 4 1.5M7 14.5l-3.5 3.5m10.5-3.5 3.5 3.5M12 12v5.5m-4-3.5-2 5.5m10-5.5 2 5.5" />
          </svg>
        </div>
        <h3 class="stat-number">2034</h3>
        <p class="stat-title">Official FIFA Host</p>
        <p class="stat-description">Selected as the sole host for the 2034 FIFA World Cup across 8 cities.</p>
      </div>

      <!-- Card 4: 98% Safety Rating -->
      <div class="verified-card">
        <div class="icon-wrapper">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <h3 class="stat-number">98%</h3>
        <p class="stat-title">Safety Rating</p>
        <p class="stat-description">Ranked among the safest countries in the world for solo travelers and families (Source: Numbeo 2026).</p>
      </div>
    </div>

    <div class="sources-link-wrapper reveal">
      <a href="/editorial-standards/" class="sources-link">Sources & References</a>
    </div>
  </div>
</section>

<style>
  .verified-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-top: 2.5rem;
  }
  .verified-card {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
  }
  .verified-card:hover {
    transform: translateY(-5px);
    border-color: rgba(201, 168, 76, 0.4);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
  }
  .icon-wrapper {
    color: var(--gold);
    background: var(--gold-dim);
    width: 50px;
    height: 50px;
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.25rem;
    transition: transform var(--transition);
  }
  .verified-card:hover .icon-wrapper {
    transform: scale(1.1);
  }
  .icon {
    width: 24px;
    height: 24px;
  }
  .stat-number {
    font-family: 'Cormorant Garamond', serif;
    font-size: 2.4rem;
    font-weight: 300;
    color: var(--gold);
    line-height: 1.1;
    margin: 0 0 0.5rem 0;
  }
  .stat-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--white);
    margin: 0 0 0.5rem 0;
    letter-spacing: 0.02em;
  }
  .stat-description {
    color: var(--white-dim);
    font-size: 0.85rem;
    line-height: 1.6;
    margin: 0;
  }
  .sources-link-wrapper {
    text-align: center;
    margin-top: 3rem;
  }
  .sources-link {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--gold-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: color var(--transition);
    border-bottom: 1px dashed var(--gold-glow);
    padding-bottom: 2px;
  }
  .sources-link:hover {
    color: var(--gold);
    border-bottom-color: var(--gold);
  }

  @media (max-width: 1024px) {
    .verified-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 640px) {
    .verified-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
